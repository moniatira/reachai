# Calendar OAuth bridge — copy to .env and fill from each provider's developer console

CP_CALENDAR_BRIDGE_HOST=127.0.0.1
CP_CALENDAR_BRIDGE_PORT=3849
# Public URL of this server (must match OAuth redirect URIs)
CP_PUBLIC_APP_URL=http://127.0.0.1:3849
# Where to send users after OAuth (your static site origin)
CP_FRONTEND_URL=http://127.0.0.1:8765

# Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client (Web)
# Enable Google Calendar API. Redirect URI: http://127.0.0.1:3849/api/calendar/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Azure Portal → App registrations → Redirect URI (Web): http://127.0.0.1:3849/api/calendar/callback/microsoft
# API permissions: Calendars.Read, User.Read, offline_access
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT=common

# Calendly Developer → OAuth app → Redirect: http://127.0.0.1:3849/api/calendar/callback/calendly
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
