# Copy this file to `.env` (same folder) and fill values there — NEVER commit real secrets.
# API reference: https://docs.athenahealth.com/api/sandbox#/Appointments

# OAuth (Preview / sandbox — confirm exact URLs in your Athena Developer Portal app)
ATHENA_TOKEN_URL=https://api.preview.platform.athenahealth.com/oauth2/v1/token
ATHENA_CLIENT_ID=
ATHENA_CLIENT_SECRET=

# Often required for Preview token calls (no default scopes on the auth server). Confirm in your app registration.
# Example pattern (may differ): athena/service/Athenanet.MDP.*
ATHENA_SCOPE=

# Classic API base (path continues with /{practiceId}/...)
ATHENA_API_BASE=https://api.preview.athenahealth.com/v1

ATHENA_PRACTICE_ID=
# Open/booked appointment APIs — see Athena dept vs patient workflow:
# https://docs.athenahealth.com/api/workflows/department-based-patient-information
ATHENA_DEPARTMENT_ID=

# Numeric Athena patient ID — used when booking slots AND passed as patientid on booked-appointment listing when set
ATHENA_PATIENT_ID=

# Local dashboard bridge (npm run portal)
# CP_ATHENA_BRIDGE_HOST=127.0.0.1
# CP_ATHENA_BRIDGE_PORT=3847

# Optional: sandbox patient display names (reminders only)
# ATHENA_SANDBOX_PATIENT_FIRST_NAME=
# ATHENA_SANDBOX_PATIENT_LAST_NAME=
